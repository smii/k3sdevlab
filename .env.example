# K3s Homelab GitOps Configuration
# Copy this file to .env and customize for your environment

# Required Domain Configuration
PUBLIC_DOMAIN=example.com
LOCAL_DOMAIN=ovie.kubernative.io
LETSENCRYPT_EMAIL=admin@example.com

# ArgoCD Configuration
ARGOCD_HOST=argocd.local.example.com
ARGOCD_NAMESPACE=argocd
ARGOCD_VERSION=5.46.8
ARGOCD_ADMIN_PASSWORD=
ARGOCD_SERVER_INSECURE=true
ARGOCD_INGRESS_ENABLED=true
ARGOCD_INGRESS_CLASS=traefik
ARGOCD_TLS_ENABLED=true

# Git Repository Configuration
GITHUB_REPO=https://github.com/smii/k3sdevlab
GIT_TARGET_REVISION=HEAD
GIT_APPS_PATH=argocd/applications
GIT_PROJECTS_PATH=argocd/projects

# ArgoCD Repository Credentials (for private repos)
GIT_USERNAME=
GIT_TOKEN=
GIT_SSH_PRIVATE_KEY_PATH=

# ArgoCD Sync Policy
AUTO_SYNC_ENABLED=true
AUTO_PRUNE_ENABLED=true
SELF_HEAL_ENABLED=true
SYNC_RETRY_LIMIT=3

# ArgoCD Applications Configuration
APPS_PROJECT=homelab
CORE_PROJECT=core-infrastructure
MONITORING_PROJECT=monitoring
SECURITY_PROJECT=security
APPLICATIONS_PROJECT=applications

# System Configuration
DRY_RUN=false
DEBUG_MODE=false

# Authelia Configuration (SSO & Authentication)
# Authelia admin user credentials
AUTHELIA_ADMIN_USERNAME=admin
AUTHELIA_ADMIN_PASSWORD=
AUTHELIA_ADMIN_EMAIL=admin@example.com

# Authelia domain configuration
AUTHELIA_DOMAIN=example.com
AUTHELIA_HOST=authelia.rtm.example.com

# Authelia secrets (will be auto-generated if left empty)
# Leave empty for automatic generation, or provide custom values
AUTHELIA_JWT_SECRET=
AUTHELIA_SESSION_SECRET=
AUTHELIA_STORAGE_ENCRYPTION_KEY=
AUTHELIA_OIDC_HMAC_SECRET=
AUTHELIA_OIDC_GITEA_CLIENT_SECRET=

# Authelia OIDC RSA Private Key Path (optional)
# If not provided, uses the key in charts/authelia/authelia-fixed.yaml
AUTHELIA_OIDC_PRIVATE_KEY_PATH=

# Organizational Structure Configuration
ORG_STRUCTURE_ENABLED=true
ORG_CONFIG_FILE=config/organizations.yaml
AUTO_SETUP_ORGS=true
AUTO_SETUP_AUTHELIA_USERS=true

# Examples of application-specific hosts (managed by ArgoCD)
# These will be configured through the individual application values files
# TRAEFIK_HOST=traefik.local.example.com
# GRAFANA_HOST=grafana.local.example.com
# HARBOR_HOST=harbor.local.example.com
# GITEA_HOST=git.example.com
# PROMETHEUS_HOST=prometheus.local.example.com
# JUPYTER_HOST=jupyter.local.example.com